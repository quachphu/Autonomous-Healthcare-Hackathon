# ── Production environment variables ──────────────────────────────────────────
# Copy to .env.local for local overrides, or set in your Vercel project dashboard.

# Backend URL (Railway / Render / Fly.io deployment).
# Leave empty in local dev — Vite proxy forwards /api/* to localhost:8000.
VITE_API_URL=https://materna-backend.railway.app

# WebSocket URL for the xAI voice agent.
# Auto-derived from VITE_API_URL if left empty (http→ws, https→wss).
# Only set this if your WS host differs from your HTTP host.
# VITE_WS_URL=wss://materna-backend.railway.app
